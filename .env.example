# STRAWBERRY CREEK API 
SCMG_API_TOKEN=your_token_here
SCMG_API_BASE_URL=https://www.strawberrycreek.org/api/creek-data/

# EMAIL ALERT SYSTEM
# Use a Gmail "App Password" if using Gmail
ALERT_EMAIL_SENDER=your_email@gmail.com
ALERT_EMAIL_PASSWORD=your_app_password
ALERT_EMAIL_RECEIVER=who_to_notify@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# MODEL SETTINGS 
HIDDEN_DIM=64
LEARNING_RATE=0.001
RAW_DATA_PATH=./full_creek_gnn.csv

# SQL DATABASE (optional, used with --data-source sql) 
# Full SQLAlchemy connection string. Examples:
#   PostgreSQL: postgresql://user:password@localhost:5432/scmg_db
#   MySQL:      mysql+pymysql://user:password@localhost:3306/scmg_db
#   SQLite:     sqlite:///path/to/scmg.db
SQL_CONNECTION_STRING=postgresql://user:password@localhost:5432/scmg_db
SQL_TABLE_NAME=creek_data
# Override these only if your table uses different column names than the API defaults
SQL_TIMESTAMP_COL=timestamp
SQL_LOCATION_COL=station_id
SQL_CONDUCTIVITY_COL=Meter_Hydros21_Cond
SQL_DEPTH_COL=Meter_Hydros21_Depth
SQL_TEMP_COL=Meter_Hydros21_Temp
SQL_RAIN_COL=TE_TR_525USW_Precip_5minTotal
SQL_TEMP2M_COL=Sensirion_SHT40_Temperature

# NWS WEATHER (no API key required)
# Station LBNL1 = Lawrence Berkeley National Laboratory (15-min precip data)
# NWS only requires a descriptive User-Agent — include your contact email.
NWS_STATION_ID=LBNL1
NWS_USER_AGENT=SCMG-AnDeSys/1.0 (your.email@example.com)
# Set to false to rely solely on the creek's own tipping-bucket gauge
USE_NWS_RAIN=true

# --- SYSTEM --- #
LOG_LEVEL=INFO