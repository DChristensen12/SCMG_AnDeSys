# --- STRAWBERRY CREEK API --- #
SCMG_API_TOKEN=your_token_here
SCMG_API_BASE_URL=https://www.strawberrycreek.org/api/creek-data/

# --- EMAIL ALERT SYSTEM --- #
# Use a Gmail "App Password" if using Gmail
ALERT_EMAIL_SENDER=your_email@gmail.com
ALERT_EMAIL_PASSWORD=your_app_password
ALERT_EMAIL_RECEIVER=who_to_notify@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# --- MODEL SETTINGS --- #
HIDDEN_DIM=64
LEARNING_RATE=0.001
RAW_DATA_PATH=./full_creek_gnn.csv

# --- EXTERNAL INTEGRATIONS --- #
OPENWEATHER_API_KEY=your_key_here

# --- SYSTEM --- #
LOG_LEVEL=INFO