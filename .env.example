# ─────────────────────────────────────────────────────────────────────────
# STRAWBERRY CREEK API (default data source — public, no setup required)
# ─────────────────────────────────────────────────────────────────────────
# The public API currently requires no token, but SCMG may re-enable auth.
# If it does, request a token at strawberrycreekmonitoringgroup@gmail.com
# and set it here. Leave blank otherwise — the client only sends an
# Authorization header when this is populated.
SCMG_API_TOKEN=
SCMG_API_BASE_URL=https://www.strawberrycreek.org/api/creek-data/

# ─────────────────────────────────────────────────────────────────────────
# MYSQL DATABASE (admin-only — most users should use the API instead)
# ─────────────────────────────────────────────────────────────────────────
# Only needed when running with --data-source sql.
# Reads directly from Night Heron's production database. Variable names
# match Night Heron's .env so the same credentials work for both projects.
#
# Schema notes: one table per site (named after site_code, lowercased),
# columns managed dynamically by Night Heron's get_creek_data.py daemon.
# Pulse's sql_client uses SHOW COLUMNS to discover what's available, so
# new sensors added to a site flow through automatically — no .env edit
# needed when the schema grows.
#
# For development from outside the OCF server, set up an SSH tunnel first:
#   ssh -L 3307:mysql:3306 your_user@your.ocf.server -N
# Then use MYSQL_HOST=127.0.0.1 and MYSQL_PORT=3307 below.
#
# For production deployment on the OCF server itself, MYSQL_HOST is
# usually 'mysql' (the Docker service name) or 'localhost'.
MYSQL_HOST= 
MYSQL_DATABASE_USER=
MYSQL_DATABASE_PASSWORD=
MYSQL_DATABASE_NAME=
MYSQL_PORT=3306

# ─────────────────────────────────────────────────────────────────────────
# NWS WEATHER (no API key required)
# ─────────────────────────────────────────────────────────────────────────
# LBNL1 = Lawrence Berkeley National Lab weather station. Pulse pulls
# multiple features (air temp, dewpoint, humidity, wind, pressure) — not
# rain, since LBNL1 doesn't have a working precipitation sensor.
#
# Caveat: NWS only serves a ~7-day rolling window for stations like LBNL1.
# Good for live operation; not usable for historical backfill.
#
# NWS requires a descriptive User-Agent with a contact email.
NWS_STATION_ID=LBNL1
NWS_USER_AGENT=SCMG-AnDeSys/1.0 (your.email@example.com)

# Whether to merge NWS weather features into the creek dataset.
# Set to false to rely solely on the creek's own onboard sensors.
USE_NWS_WEATHER=true


# How many days of data to keep in the local cache (data/processed_data/full_creek_gnn.csv).
# Cache trims older rows. 90 days is a good default — long enough for debugging
# and ad-hoc retrains, small enough that the file stays under a few MB.
ROLLING_WINDOW_DAYS=90

# ─────────────────────────────────────────────────────────────────────────
# EMAIL ALERT SYSTEM
# ─────────────────────────────────────────────────────────────────────────
# Used by src/utils/notifier.py to send spill alerts when running in
# inference mode. Use a Gmail "App Password" if using Gmail (regular
# passwords don't work with SMTP since Google enforced 2FA).
ALERT_EMAIL_SENDER=your_email@gmail.com
ALERT_EMAIL_PASSWORD=your_app_password
ALERT_EMAIL_RECEIVER=who_to_notify@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# ─────────────────────────────────────────────────────────────────────────
# MODEL & DATA SETTINGS
# ─────────────────────────────────────────────────────────────────────────
# Most model hyperparameters live in config/settings.yaml. Only override
# here if you want a quick per-run change without editing the YAML.
HIDDEN_DIM=64
LEARNING_RATE=0.001
RAW_DATA_PATH=./full_creek_gnn.csv

# ─────────────────────────────────────────────────────────────────────────
# SYSTEM
# ─────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO


